<Window x:Class="RemoteMate.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RemoteMate - Dashboard" Height="750" Width="1250"
        WindowStartupLocation="CenterScreen" Background="#F0F2F5"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewKeyUp="Window_PreviewKeyUp">

    <Grid x:Name="mainRootGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="colSidebar" Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#1e272e">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="20,25,20,0">
                    <TextBlock Text="🌐 REMOTEMATE" Foreground="#34e7e4" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <Separator Margin="0,15,0,10" Background="#3d4e5e"/>
                </StackPanel>

                <Border Grid.Row="1" Background="#2c3e50" CornerRadius="12" Margin="15,5,15,15" Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Ellipse Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" 
                 Width="32" Height="32" VerticalAlignment="Center" Margin="0,0,10,0" 
                 Cursor="Hand" MouseDown="profileDot_MouseDown">
                            <Ellipse.Fill>
                                <ImageBrush ImageSource="/Images/avatar.jpg" Stretch="UniformToFill"/>
                            </Ellipse.Fill>
                        </Ellipse>

                        <TextBlock x:Name="txtProfileName" Grid.Row="0" Grid.Column="1" 
                   Text="" Foreground="White" FontWeight="SemiBold" FontSize="15" 
                   VerticalAlignment="Center"/>

                        <Button Name="btnLogout" Grid.Row="0" Grid.Column="2" 
                            Content="🚪 Đăng xuất" VerticalAlignment="Center" 
                            Background="Transparent" Foreground="#e74c3c" BorderThickness="0" 
                            FontSize="13" Cursor="Hand" Click="BtnLogout_Click"/>

                        <TextBlock x:Name="txtProfileEmail" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                           Text="" Foreground="#95a5a6" FontSize="13" Margin="0,2,0,0"
                           TextWrapping="NoWrap" TextTrimming="None"/>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="2" Margin="15,0">
                    <DockPanel LastChildFill="False" Margin="0,0,0,10">
                        <TextBlock Text="💻 DANH SÁCH THIẾT BỊ" Foreground="#bdc3c7" FontSize="12" VerticalAlignment="Center"/>
                        <Button DockPanel.Dock="Right" Content="Refresh" FontSize="10" Padding="8,2" Background="#3d4e5e" Foreground="White" BorderThickness="0" Click="BtnRefresh_Click"/>
                    </DockPanel>

                    <ListBox Name="lstClients" Background="#2c3e50" BorderThickness="0" Height="230" Foreground="White" ScrollViewer.VerticalScrollBarVisibility="Auto" MouseDoubleClick="lstClients_MouseDoubleClick"/>

                    <TextBlock Text="📋 LỊCH SỬ PHIÊN GẦN ĐÂY"
                           Foreground="#bdc3c7"
                           FontSize="12"
                           Margin="0,20,0,8"/>

                    <Border Background="#2c3e50"
                            CornerRadius="0"
                            Padding="8"
                            Height="220">

                        <ListBox Name="lstHistory"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#dfe6e9"
                                 FontSize="10"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">

                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="2"/>
                                    <Setter Property="Margin" Value="0,2,0,2"/>
                                    <Setter Property="Foreground" Value="#dfe6e9"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </ListBox.ItemContainerStyle>

                        </ListBox>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="rowHeader" Height="Auto"/>
                <RowDefinition x:Name="rowToolbar" Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition x:Name="rowFooter" Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Margin="20,20,20,0" Padding="15" Background="White" CornerRadius="12">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Name="ledConnection" Width="12" Height="12" Fill="#e74c3c" Margin="0,0,10,0"/>
                        <TextBlock Name="txtConnectionStatus" Text="Trạng thái: Sẵn sàng kết nối" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="IP Đích: " Foreground="#7f8c8d" VerticalAlignment="Center"/>
                        <TextBlock Name="txtRemoteMachine" Text="Chưa chọn" Foreground="#2c3e50" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Name="btnDisconnect" Content="Ngắt kết nối" Margin="20,0,0,0" 
                                Background="#e74c3c" Foreground="White" BorderThickness="0" 
                                Padding="15,5" Visibility="Collapsed" Click="BtnDisconnect_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1" Margin="20,10,20,0" Padding="10" Background="White" CornerRadius="12">
                <UniformGrid Columns="5">
                    <ToggleButton Name="btnControlMode" Content="🎮 ĐIỀU KHIỂN" Height="45" Margin="5" Background="#4834d4" Foreground="White" FontWeight="Bold" Checked="BtnControlMode_Checked" Unchecked="BtnControlMode_Unchecked"/>
                    <Button Name="btnFileTransfer" Content="💬 CHAT" Height="45" Margin="5" Background="#00b894" Foreground="White" FontWeight="Bold" Click="BtnFileTransfer_Click"/>
                    <Button Name="btnScreenshot" Content="📸 CHỤP ẢNH" Height="45" Margin="5" Background="#2d3436" Foreground="White" FontWeight="Bold" Click="BtnScreenshot_Click"/>
                    <Button Name="btnLockScreen" Content="🔒 KHÓA MÁY" Height="45" Margin="5" Background="#e67e22" Foreground="White" FontWeight="Bold" Click="BtnLockScreen_Click"/>
                    <Button Name="btnShutdown" Content="⛔ TẮT MÁY" Height="45" Margin="5" Background="#eb4d4b" Foreground="White" FontWeight="Bold" Click="BtnShutdown_Click"/>
                </UniformGrid>
            </Border>

            <Border Grid.Row="2"
                x:Name="borderScreenArea"
                Margin="20,10,20,10"
                Background="#2d3436"
                CornerRadius="15"
                BorderBrush="#38bdf8"
                BorderThickness="1"
                MouseEnter="borderScreenArea_MouseEnter"
                MouseLeave="borderScreenArea_MouseLeave">

                <Grid ClipToBounds="True">

                    <Grid Panel.ZIndex="0"
                          ClipToBounds="True"
                          Background="#2d3436">

                        <Image Name="imgRemoteScreen"
                   Stretch="Uniform"
                   StretchDirection="Both"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch"
                   Focusable="True"
                   MouseMove="ImgRemoteScreen_MouseMove"
                   MouseDown="ImgRemoteScreen_MouseDown"
                   MouseUp="ImgRemoteScreen_MouseUp"
                   MouseWheel="ImgRemoteScreen_MouseWheel"
                   Visibility="Collapsed"/>
                    </Grid>

                    <StackPanel Name="pnlPlaceholder"
                    Panel.ZIndex="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                        <TextBlock Text="🖥️"
                       FontSize="60"
                       Foreground="#576574"
                       HorizontalAlignment="Center"/>
                        <TextBlock Text="Chọn một thiết bị và nhấn 'ĐIỀU KHIỂN'"
                       Foreground="#95a5a6"
                       FontSize="15"
                       Margin="0,15,0,0"
                       FontWeight="Bold"/>
                    </StackPanel>

                    <Canvas x:Name="canvasOverlay"
                        Panel.ZIndex="99"
                        SizeChanged="canvasOverlay_SizeChanged">
                        <Button x:Name="btnMaximize"
                            Content="⛶"
                            Width="42"
                            Height="42"
                            Canvas.Left="720"
                            Canvas.Top="12"
                            FontSize="22"
                            FontWeight="Bold"
                            Foreground="#B6FF00"
                            Background="#CC000000"
                            BorderBrush="#B6FF00"
                            BorderThickness="2"
                            Cursor="SizeAll"
                            Visibility="Collapsed"
                            PreviewMouseLeftButtonDown="btnMaximize_PreviewMouseLeftButtonDown"
                            PreviewMouseMove="btnMaximize_PreviewMouseMove"
                            PreviewMouseLeftButtonUp="btnMaximize_PreviewMouseLeftButtonUp"
                            ToolTip="Phóng to / Thu nhỏ màn hình">          
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="21">
                                        <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                                    </Border>

                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#B6FF00"/>
                                            <Setter Property="Foreground" Value="#111111"/>
                                        </Trigger>

                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#7CFC00"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Canvas>

                </Grid>
            </Border>

            <Border Grid.Row="3" Margin="20,0,20,15">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <TextBlock Text="FPS: " Foreground="#7f8c8d" FontSize="11"/>
                        <TextBlock Name="txtFps" Text="0" Foreground="#00d2d3" FontWeight="Bold" FontSize="11" Margin="0,0,20,0"/>
                        <TextBlock Text="Frame Delay: " Foreground="#7f8c8d" FontSize="11"/>
                        <TextBlock Name="txtLatency" Text="-- ms" Foreground="#00d2d3" FontWeight="Bold" FontSize="11"/>
                    </StackPanel>
                    <TextBlock Text="RemoteMate v1.0" Foreground="#95a5a6" FontSize="11" HorizontalAlignment="Right"/>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>