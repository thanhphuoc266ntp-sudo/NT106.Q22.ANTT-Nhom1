<Window x:Class="RemoteMate.Views.ConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Xác nhận truy cập"
        Height="220" Width="380"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#F5F6FA"
        AllowsTransparency="True">

    <Border CornerRadius="15" Background="White" Padding="20" 
            BorderBrush="#E0E0E0" BorderThickness="1">

        <StackPanel>

            <!-- Icon + Title -->
            <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                <TextBlock Text="🖥️" FontSize="24" Margin="0 0 10 0"/>
                <TextBlock Text="Yêu cầu điều khiển"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Nội dung -->
            <TextBlock x:Name="txtInfo"
                       Text="Một người đang yêu cầu truy cập máy của bạn"
                       TextWrapping="Wrap"
                       Foreground="#555"
                       Margin="0 0 0 20"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                <!-- Reject -->
                <Button Content="Từ chối"
                        Width="100"
                        Height="35"
                        Margin="5"
                        Background="#ECF0F1"
                        Foreground="#333"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="Reject_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="10"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Accept -->
                <Button Content="Cho phép"
                        Width="100"
                        Height="35"
                        Margin="5"
                        Background="#4CAF50"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="Accept_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="10"
                                                Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

            </StackPanel>

        </StackPanel>
    </Border>
</Window>