<Window x:Class="RemoteMate.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RemoteMate - Login" Height="500" Width="800"
        WindowStartupLocation="CenterScreen" Background="#0f172a">

    <Grid>
        <Border Width="350" Height="420" Background="#1e293b" CornerRadius="15" Padding="30">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Opacity="0.3" ShadowDepth="0"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="REMOTEMATE" Foreground="#38bdf8" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="Đăng nhập" Foreground="White" FontSize="18" Margin="0,20,0,10" HorizontalAlignment="Center"/>

                <Grid Margin="0,10,0,0">
                    <TextBox Name="txtUsername" Height="40" Background="#334155" Foreground="White" BorderThickness="0" Padding="10" VerticalContentAlignment="Center" TextChanged="txtUsername_TextChanged" VerticalAlignment="Top"/>
                    <TextBlock Name="placeholderUser" Text="Tên đăng nhập hoặc Email" Foreground="#94a3b8" IsHitTestVisible="False" VerticalAlignment="Center" Margin="12,0,0,0" Visibility="Visible"/>
                </Grid>

                <Grid Margin="0,10,0,0">
                    <PasswordBox Name="txtPassword" Height="40" Background="#334155" Foreground="White" BorderThickness="0" Padding="10" VerticalContentAlignment="Center" PasswordChanged="txtPassword_PasswordChanged"/>
                    <TextBlock Name="placeholderPass" Text="Mật khẩu" Foreground="#94a3b8" IsHitTestVisible="False" VerticalAlignment="Center" Margin="12,0,0,0" Visibility="Visible"/>
                </Grid>

                <Button Name="btnLogin" Content="Đăng nhập" Height="45" Margin="0,25,0,0" Background="#38bdf8" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="btnLogin_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <TextBlock Text="Đăng ký tài khoản" Foreground="#38bdf8" Margin="0,15,0,0" HorizontalAlignment="Center" Cursor="Hand" PreviewMouseLeftButtonDown="MoTrangDangKy_Click" />

                <TextBlock Text="Quên mật khẩu?" Foreground="#94a3b8" Margin="0,10,0,0" HorizontalAlignment="Center" Cursor="Hand" PreviewMouseLeftButtonDown="QuenMatKhau_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>