<Window x:Class="RemoteMate.ForgotPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RemoteMate - Reset Password" Height="400" Width="420"
        WindowStartupLocation="CenterScreen" Background="#0f172a">
    <Grid>
        <Border Margin="25" Background="#1e293b" CornerRadius="15" Padding="25">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="QUÊN MẬT KHẨU" Foreground="#38bdf8" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="Nhập Email bạn đã đăng ký để khôi phục mật khẩu" Foreground="#94a3b8" FontSize="13" HorizontalAlignment="Center" Margin="0,15,0,25" TextWrapping="Wrap" TextAlignment="Center"/>

                <TextBlock Text="Email" FontSize="14" Foreground="White" Margin="0,0,0,5"/>
                <TextBox Name="txtResetEmail" Height="40" FontSize="14" Background="#334155" Foreground="White" BorderThickness="0" Padding="10" VerticalContentAlignment="Center"/>

                <Button Name="btnReset" Content="GỬI YÊU CẦU" Height="45" Margin="0,30,0,0" Background="#38bdf8" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="btnReset_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <TextBlock Text="Quay lại Đăng nhập" FontSize="13" Foreground="#94a3b8" Margin="0,20,0,0" HorizontalAlignment="Center" Cursor="Hand" PreviewMouseLeftButtonDown="BackToLogin_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>