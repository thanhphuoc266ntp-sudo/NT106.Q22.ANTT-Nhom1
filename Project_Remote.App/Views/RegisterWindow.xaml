<Window x:Class="RemoteMate.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RemoteMate - Sign Up" Height="680" Width="450" 
        WindowStartupLocation="CenterScreen" Background="#0f172a">
    <Grid>
        <Border Margin="30" Background="#1e293b" CornerRadius="15" Padding="25">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Opacity="0.3" ShadowDepth="0"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="ĐĂNG KÝ HỆ THỐNG" Foreground="#38bdf8" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                <TextBlock Text="Họ và Tên" FontSize="14" Foreground="White" Margin="0,5,0,5"/>
                <TextBox Name="txtFullName" Height="40" FontSize="14" Background="#334155" Foreground="White" BorderThickness="0" Padding="10" VerticalContentAlignment="Center"/>

                <TextBlock Text="Tên đăng nhập" FontSize="14" Foreground="White" Margin="0,10,0,5"/>
                <TextBox Name="txtUser" Height="40" FontSize="14" Background="#334155" Foreground="White" BorderThickness="0" Padding="10" VerticalContentAlignment="Center"/>

                <TextBlock Text="Email" FontSize="14" Foreground="White" Margin="0,10,0,5"/>
                <TextBox Name="txtEmail" Height="40" FontSize="14" Background="#334155" Foreground="White" BorderThickness="0" Padding="10" VerticalContentAlignment="Center"/>

                <TextBlock Text="Mật khẩu" FontSize="14" Foreground="White" Margin="0,10,0,5"/>
                <PasswordBox Name="txtPass" Height="40" FontSize="14" Background="#334155" Foreground="White" BorderThickness="0" Padding="10" VerticalContentAlignment="Center"/>

                <TextBlock Text="Nhập lại mật khẩu" FontSize="14" Foreground="White" Margin="0,10,0,5"/>
                <PasswordBox Name="txtConfirmPassword" Height="40" FontSize="14" Background="#334155" Foreground="White" BorderThickness="0" Padding="10" VerticalContentAlignment="Center"/>

                <Button Name="btnRegister" Content="GỬI YÊU CẦU ĐĂNG KÝ" Height="45" Margin="0,30,0,0" 
                        Background="#38bdf8" Foreground="White" FontWeight="Bold" 
                        BorderThickness="0" Cursor="Hand" Click="btnRegister_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <TextBlock Text="Quay lại Đăng nhập" FontSize="13" Foreground="#94a3b8" Margin="0,20,0,0" HorizontalAlignment="Center" Cursor="Hand" PreviewMouseLeftButtonDown="BackToLogin_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>