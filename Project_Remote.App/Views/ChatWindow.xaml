<Window x:Class="RemoteMate.Views.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RemoteMate - Chat"
        Height="520"
        Width="430"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F0F2F5">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#1E2A32"
                CornerRadius="10"
                Padding="12"
                Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="💬 CHAT HỖ TRỢ"
                           Foreground="#00F5FF"
                           FontSize="16"
                           FontWeight="Bold"/>
                <TextBlock x:Name="txtRemoteInfo"
                           Text="Đang chat với: Chưa chọn"
                           Foreground="#DDE6ED"
                           FontSize="13"
                           Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="10"
                BorderBrush="#D0D7DE"
                BorderThickness="1"
                Padding="8">
            <ScrollViewer x:Name="scrollMessages"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="pnlMessages"/>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="48"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="txtMessage"
             Grid.Column="0"
             Height="42"
             FontSize="14"
             VerticalContentAlignment="Center"
             Padding="10,0"
             BorderBrush="#B0BEC5"
             BorderThickness="1"
             KeyDown="txtMessage_KeyDown"/>

            <Button x:Name="btnAttachFile"
            Grid.Column="1"
            Content="📤"
            Height="42"
            Margin="8,0,0,0"
            FontSize="18"
            Background="#34495E"
            Foreground="White"
            FontWeight="Bold"
            ToolTip="Gửi file"
            Click="btnAttachFile_Click"/>

            <Button x:Name="btnSend"
            Grid.Column="2"
            Content="Gửi"
            Height="42"
            Margin="8,0,0,0"
            Background="#00B894"
            Foreground="White"
            FontWeight="Bold"
            Click="btnSend_Click"/>
        </Grid>
    </Grid>
</Window>