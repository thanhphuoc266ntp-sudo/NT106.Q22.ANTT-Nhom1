<Window x:Class="RemoteMate.ResetPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RemoteMate - Reset Password" Height="450" Width="400"
        WindowStartupLocation="CenterScreen" Background="#0f172a">
    <Grid>
        <Border Margin="20" Background="#1e293b" CornerRadius="15" Padding="25">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="ĐẶT LẠI MẬT KHẨU" Foreground="#38bdf8" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <StackPanel Name="stepVerifyOTP" Visibility="Visible">
                    <TextBlock Text="Nhập mã xác thực được gửi về Email" Foreground="#94a3b8" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <TextBlock Text="Mã xác thực" FontSize="14" Foreground="White" Margin="0,0,0,5"/>
                    <TextBox Name="txtOTP" Height="40" Background="#334155" Foreground="White" BorderThickness="0" Padding="10" VerticalContentAlignment="Center"/>

                    <Button Content="XÁC THỰC MÃ" FontSize="16" Height="45" Margin="0,25,0,0" Background="#38bdf8" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="btnVerifyOTP_Click"/>

                    <Button Name="btnResend" Content="Gửi lại mã xác thực" Background="Transparent" Foreground="#94a3b8" BorderThickness="0" Cursor="Hand" Margin="0,15,0,0" FontSize="14" HorizontalAlignment="Center" Click="btnResend_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <TextBlock Text="{TemplateBinding Content}" Background="Transparent"/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#38bdf8"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <StackPanel Name="stepNewPassword" Visibility="Collapsed">
                    <TextBlock Text="Xác thực thành công! Vui lòng nhập mật khẩu mới." Foreground="#4ade80" FontSize="13" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <TextBlock Text="Mật khẩu mới" Foreground="White" Margin="0,0,0,5"/>
                    <PasswordBox Name="txtNewPassword" Height="40" Background="#334155" Foreground="White" BorderThickness="0" Padding="10" VerticalContentAlignment="Center"/>

                    <TextBlock Text="Xác nhận mật khẩu" Foreground="White" Margin="0,15,0,5"/>
                    <PasswordBox Name="txtConfirmPassword" Height="40" Background="#334155" Foreground="White" BorderThickness="0" Padding="10" VerticalContentAlignment="Center"/>

                    <Button Content="CẬP NHẬT MẬT KHẨU" Height="45" Margin="0,25,0,0" Background="#4ade80" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="btnUpdatePassword_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>