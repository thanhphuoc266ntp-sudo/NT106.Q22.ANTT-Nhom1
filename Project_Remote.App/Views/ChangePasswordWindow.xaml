<Window x:Class="RemoteMate.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RemoteMate - Change Password" Height="500" Width="450"
        WindowStartupLocation="CenterScreen" Background="#0f172a"
        MinHeight="480" MinWidth="400">
    <Grid>
        <Border Margin="25" Background="#1e293b" CornerRadius="15" Padding="25">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="ĐỔI MẬT KHẨU" Foreground="#38bdf8" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                <TextBlock Text="Mật khẩu cũ" FontSize="14" Foreground="White" Margin="0,0,0,5"/>
                <PasswordBox Name="txtOldPassword" Height="40" FontSize="14" Background="#334155" Foreground="White" BorderThickness="0" Padding="10" VerticalContentAlignment="Center"/>

                <TextBlock Text="Mật khẩu mới" FontSize="14" Foreground="White" Margin="0,15,0,5"/>
                <PasswordBox Name="txtNewPassword" Height="40" FontSize="14" Background="#334155" Foreground="White" BorderThickness="0" Padding="10" VerticalContentAlignment="Center"/>

                <TextBlock Text="Nhập lại mật khẩu mới" FontSize="14" Foreground="White" Margin="0,15,0,5"/>
                <PasswordBox Name="txtConfirmPassword" Height="40" FontSize="14" Background="#334155" Foreground="White" BorderThickness="0" Padding="10" VerticalContentAlignment="Center"/>

                <Button Name="btnChangePassword" Content="ĐỔI MẬT KHẨU" Height="45" Margin="0,30,0,0" Background="#38bdf8" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="btnChangePassword_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>