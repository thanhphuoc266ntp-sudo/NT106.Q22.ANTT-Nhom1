<Window x:Class="RemoteMate.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RemoteMate - Profile" Height="490" Width="452"
        WindowStartupLocation="CenterScreen" Background="#0f172a">
    <Grid Margin="0,0,0,-16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="281*"/>
            <ColumnDefinition Width="171*"/>
        </Grid.ColumnDefinitions>
        <Border Margin="25,25,26,46" Background="#1e293b" CornerRadius="15" Padding="25" Grid.ColumnSpan="2">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="HỒ SƠ NGƯỜI DÙNG" Foreground="#38bdf8" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                <TextBlock Text="Họ và tên" FontSize="14" Foreground="White" Margin="0,0,0,5"/>
                <TextBox Name="txtFullName" Height="40" FontSize="14" Background="#334155" Foreground="White" BorderThickness="0" Padding="10" VerticalContentAlignment="Center"/>

                <TextBlock Text="Tên đăng nhập" FontSize="14" Foreground="White" Margin="0,15,0,5"/>
                <TextBox Name="txtUsername" Height="40" FontSize="14" Background="#334155" Foreground="White" BorderThickness="0" Padding="10" VerticalContentAlignment="Center"/>

                <TextBlock Text="Email" FontSize="14" Foreground="White" Margin="0,15,0,5"/>
                <TextBox Name="txtEmail" Height="40" FontSize="14" Background="#334155" Foreground="#94a3b8" BorderThickness="0" Padding="10" VerticalContentAlignment="Center" IsReadOnly="True"/>

                <Button Name="btnUpdate" Content="CẬP NHẬT" Height="45" Margin="0,30,0,0" Background="#38bdf8" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="btnUpdate_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>